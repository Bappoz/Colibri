---
// Ícones inline em SVG (estilo line-icon, herdam currentColor via .icon).
// Substituem emojis. Para trocar por um ícone específico do Flaticon,
// baixe o SVG e cole o <path> correspondente no mapa abaixo.
interface Props {
  name: keyof typeof paths;
  label?: string;
}
const { name, label } = Astro.props;

const paths: Record<string, string> = {
  alert:
    '<path d="M12 3 2 20h20L12 3z"/><line x1="12" y1="9" x2="12" y2="14"/><line x1="12" y1="17.5" x2="12" y2="17.5"/>',
  star:
    '<path d="M12 3l2.6 5.8 6.4.6-4.8 4.3 1.4 6.3L12 17.3 6.8 20.3l1.4-6.3L3.4 9.7l6.4-.6L12 3z"/>',
  info:
    '<circle cx="12" cy="12" r="9"/><line x1="12" y1="11" x2="12" y2="16"/><line x1="12" y1="8" x2="12" y2="8"/>',
  check:
    '<circle cx="12" cy="12" r="9"/><path d="M8 12.5l2.5 2.5L16 9.5"/>',
  target:
    '<circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="4.5"/><circle cx="12" cy="12" r="0.6"/>',
  book:
    '<path d="M4 5.5A1.5 1.5 0 0 1 5.5 4H19v14H5.5A1.5 1.5 0 0 0 4 19.5z"/><line x1="4" y1="19.5" x2="4" y2="5.5"/>',
};
---
<svg
  class="icon"
  viewBox="0 0 24 24"
  stroke-width="1.9"
  stroke-linecap="round"
  stroke-linejoin="round"
  role={label ? 'img' : 'presentation'}
  aria-label={label}
  aria-hidden={label ? undefined : 'true'}
  set:html={paths[name]}
/>
